APP_NAME="solidtime"
VITE_APP_NAME="solidtime"
APP_ENV="production"
APP_DEBUG="false"
APP_URL="http://localhost:8000"
APP_FORCE_HTTPS="false"

# Authentication — generated by: docker compose run --rm scheduler php artisan self-host:generate-keys
APP_KEY=""
PASSPORT_PRIVATE_KEY=""
PASSPORT_PUBLIC_KEY=""

# Super admin email
SUPER_ADMINS=""

# Logging
LOG_CHANNEL="stderr_daily"
LOG_LEVEL="info"

# Database
DB_CONNECTION="pgsql"
DB_HOST="database"
DB_PORT="5432"
DB_SSLMODE="disable"
DB_DATABASE="solidtime"
DB_USERNAME="solidtime"
DB_PASSWORD=""

# Mail — using log driver for local use, no SMTP needed
MAIL_MAILER="log"
MAIL_FROM_ADDRESS="no-reply@localhost"
MAIL_FROM_NAME="solidtime"

# Queue
QUEUE_CONNECTION="database"

# File storage
FILESYSTEM_DISK="local"
PUBLIC_FILESYSTEM_DISK="public"

# Services
GOTENBERG_URL="http://gotenberg:3000"
